<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <template id="report_dispatch_note" inherit_id="stock_dispatch_note_report.report_dispatch_note">
        <xpath expr="//th[@id='move_line_done_product']" position="before">
            <th id="move_line_done_package"><strong>Package</strong></th>
        </xpath>

        <xpath expr="//td[@id='move_line_done_product_id']" position="before">
            <td id="move_line_done_package_id">
                <span t-field="move_line.package_id"/>
            </td>
        </xpath>
    </template>
</odoo>
